FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
RUN chmod +x start.sh stop.sh install.sh

RUN mkdir -p /root/.ghost /root/.ghost/cron /root/.ghost/skills \
    /root/.ghost/plugins /root/.ghost/screenshots /root/.ghost/evolve/backups

ENV GHOST_BIND_HOST=0.0.0.0

EXPOSE 3333

CMD ["python3", "ghost.py", "start"]
